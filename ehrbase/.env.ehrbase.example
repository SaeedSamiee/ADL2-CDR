# EhrBase / ADL2 CDR deployment configuration
# Copy to .env.ehrbase and adjust for your environment:
#   cp .env.ehrbase.example .env.ehrbase
#
# Used by docker compose (env_file) and referenced in README deployment guide.

# --- PostgreSQL (required for docker / production Spring profile) ---
# JDBC URL. Use host "ehrdb" with bundled compose; use your RDS/VM hostname for external DB.
DB_URL=jdbc:postgresql://ehrdb:5432/ehrbase
# Optional SSL, e.g. jdbc:postgresql://db.example.com:5432/ehrbase?sslmode=require

# Runtime application user (SELECT/INSERT/UPDATE/DELETE on schema ehr)
DB_USER=ehrbase_restricted
DB_PASS=ehrbase_restricted

# Flyway migration user (DDL on schema ehr)
DB_USER_ADMIN=ehrbase
DB_PASS_ADMIN=ehrbase

# Bundled Postgres container init (docker-compose.yml ehrdb service; keep aligned with DB_* above)
EHRBASE_USER_ADMIN=ehrbase
EHRBASE_PASSWORD_ADMIN=ehrbase
EHRBASE_USER=ehrbase_restricted
EHRBASE_PASSWORD=ehrbase_restricted
POSTGRES_PASSWORD=postgres

# --- Server identity ---
SERVER_NODENAME=local.ehrbase.org

# --- Authentication (docker profile defaults to BASIC) ---
SECURITY_AUTHTYPE=BASIC
SECURITY_AUTHUSER=ehrbase-user
SECURITY_AUTHPASSWORD=SuperSecretPassword
SECURITY_AUTHADMINUSER=ehrbase-admin
SECURITY_AUTHADMINPASSWORD=EvenMoreSecretPassword
SECURITY_OAUTH2USERROLE=USER
SECURITY_OAUTH2ADMINROLE=ADMIN
# OAuth example (uncomment when using Keycloak from docker-compose):
# SECURITY_AUTHTYPE=OAUTH
# SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUERURI=http://keycloak:8080/auth/realms/ehrbase

# --- Optional: custom container image (built JAR from this repo) ---
# EHRBASE_IMAGE=adl2-cdr/ehrbase:local

# --- Management endpoints (optional) ---
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE=env,health,info,metrics,prometheus
MANAGEMENT_ENDPOINTS_WEB_BASEPATH=/management
MANAGEMENT_ENDPOINT_ENV_ENABLED=false
MANAGEMENT_ENDPOINT_HEALTH_ENABLED=false
MANAGEMENT_ENDPOINT_HEALTH_DATASOURCE_ENABLED=false
MANAGEMENT_ENDPOINT_INFO_ENABLED=false
MANAGEMENT_ENDPOINT_METRICS_ENABLED=false
MANAGEMENT_ENDPOINT_PROMETHEUS_ENABLED=false
MANAGEMENT_ENDPOINT_HEALTH_PROBES_ENABLED=false
