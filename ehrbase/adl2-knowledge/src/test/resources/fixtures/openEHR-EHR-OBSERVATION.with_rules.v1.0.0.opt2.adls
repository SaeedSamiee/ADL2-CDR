operational_template (adl_version=2.0.5; rm_release=1.0.2; generated)
    openEHR-EHR-OBSERVATION.with_rules.v1.0.0

language
    original_language = <[ISO_639-1::en]>

description
    original_author = <
        ["name"] = <"Pieter Bos">
    >
    lifecycle_state = <"published">
    copyright = <"copyright © 2004 openEHR Foundation <http://www.openEHR.org>">
    other_details = <
        ["regression"] = <"PASS">
    >
    details = <
        ["en"] = <
            language = <[ISO_639-1::en]>
            purpose = <"Test for rules, simple constant arithmetics">
            keywords = <"ADL", "test">
        >
    >

definition
    OBSERVATION[id1] occurrences matches {0..*} matches {    -- Blood Pressure
        data matches {
            HISTORY[id2] occurrences matches {0..1} matches {    -- History
                events cardinality matches {1..*; unordered} matches {
                    EVENT[id3] occurrences matches {1..*} matches {    -- Any event
                        data matches {
                            ITEM_TREE[id4] occurrences matches {0..1} matches {    -- Blood pressure detail
                                items cardinality matches {3; unordered} matches {
                                    ELEMENT[id5] occurrences matches {0..3} matches {    -- systolic
                                        value matches {
                                            DV_QUANTITY[id13] occurrences matches {0..1} matches {
                                                [magnitude, units, precision] matches {
                                                    [{|0.0..<1000.0|}, {"mmHg"}, {1}]
                                                }
                                            }
                                        }
                                    }
                                    ELEMENT[id6] occurrences matches {0..3} matches {    -- diastolic
                                        value matches {
                                            DV_QUANTITY[id14] occurrences matches {0..1} matches {
                                                [magnitude, units, precision] matches {
                                                    [{|0.0..<1000.0|}, {"mmHg"}, {1}]
                                                }
                                            }
                                        }
                                    }
                                    ELEMENT[id7] occurrences matches {0..3} matches {    -- pulse pressure
                                        value matches {
                                            DV_QUANTITY[id15] occurrences matches {0..1} matches {
                                                [magnitude, units, precision] matches {
                                                    [{|0.0..<1000.0|}, {"mmHg"}, {1}]
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

rules
    $systolic:Real ::= /data[id2]/events[id3]/data[id4]/items[id5]/value/magnitude
    $diastolic:Real ::= /data[id2]/events[id3]/data[id4]/items[id6]/value/magnitude
    blood_pressure: /data[id2]/events[id3]/data[id4]/items[id7]/value/magnitude = $systolic - $diastolic
    systolic_greater_than_diastolic: $systolic > $diastolic
    $flattened_path_arguments:Real ::= min(/data[id2]/events[id3]/data[id4]/items[id5]/value/magnitude, 
        /data[id2]/events[id3]/data[id4]/items[id6]/value/magnitude)

terminology
    term_definitions = <
        ["en"] = <
            ["id1"] = <
                text = <"Blood Pressure">
                description = <"The local measurement of arterial blood pressure which is a surrogate for arterial. pressure in the systemic circulation.  Most commonly, use of the term 'blood pressure' refers to measurement of brachial artery pressure in the upper arm.">
            >
            ["id2"] = <
                text = <"History">
                description = <"History of blood pressure measurements">
            >
            ["id3"] = <
                text = <"Any event">
                description = <"Single blood pressure measurement event">
            >
            ["id4"] = <
                text = <"Blood pressure detail">
                description = <"Systolic, diastolic and derived values">
            >
            ["id5"] = <
                text = <"systolic">
                description = <"Systolic Pressure">
            >
            ["id6"] = <
                text = <"diastolic">
                description = <"Diastolic Pressure">
            >
            ["id7"] = <
                text = <"pulse pressure">
                description = <"Calculated as systolic minus diastolic (rule: blood_pressure)">
            >
        >
    >

component_terminologies
    component_terminologies = < 
    > 